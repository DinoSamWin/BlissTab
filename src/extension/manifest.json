{
    "manifest_version": 3,
    "name": "StartlyTab",
    "version": "1.0.1",
    "description": "A small pause, built into your day. A beautiful new tab page with gateway shortcuts.",
    "permissions": [
        "bookmarks",
        "scripting",
        "storage",
        "management",
        "tabs",
        "activeTab",
        "favicon",
        "contextMenus",
        "identity",
        "downloads",
        "offscreen"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://accounts.google.com https://*.googleapis.com https://*.firebaseapp.com https://*.firebase.com https://*.supabase.co https://open.bigmodel.cn https://api.siliconflow.cn https://api.deepseek.com https://cloud.umami.is https://workers.cloudflare.com;"
    },
    "oauth2": {
        "client_id": "4260709449-hvmd55u8rt4vrfrh8sduqkcjr3f35gar.apps.googleusercontent.com",
        "scopes": [
            "openid",
            "email",
            "profile"
        ]
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "action": {
        "default_popup": "src/extension/popup.html",
        "default_title": "Add Gateway"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+U",
                "mac": "Command+Shift+U"
            },
            "description": "Open Gateway Adder"
        }
    },
    "icons": {
        "128": "icons/icon-512x512.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "externally_connectable": {
        "matches": [
            "http://localhost:*/*",
            "http://127.0.0.1:*/*",
            "https://startlytab.com/*",
            "https://*.vercel.app/*",
            "https://startlytab.featurebase.app/*"
        ]
    }
}